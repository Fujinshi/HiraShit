<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ThemeOverlay">
        <item name="dialogPreferenceStyle">@null</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
    </style>

    <style name="ThemeOverlay.Black">
        <item name="colorSurface">@color/dark_bg_primary</item>
        <item name="android:colorBackground">@color/dark_bg_primary</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorSecondary">@color/neon_magenta</item>
    </style>
    
    <!-- Neon Theme Overlay -->
    <style name="ThemeOverlay.Neon" parent="ThemeOverlay">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_blue</item>
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="android:colorBackground">@color/dark_bg_primary</item>
    </style>
</resources>