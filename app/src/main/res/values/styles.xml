<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.DarkNeon" />

    <style name="Widget.Design.SubtitleCollapsingToolbar" parent="Widget.Design.CollapsingToolbar" />

    <style name="TextAppearance.Design.SubtitleCollapsingToolbar.ExpandedTitle" parent="TextAppearance.Design.CollapsingToolbar.Expanded" />

    <style name="TextAppearance.Design.SubtitleCollapsingToolbar.ExpandedSubtitle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/text_secondary_neon</item>
    </style>

    <style name="language_menu_style" parent="ThemeOverlay.Preference.SimpleMenuPreference.PopupMenu">
        <item name="android:textAlignment">textStart</item>
    </style>

    <style name="Widget.Button.TextButton.Dialog.FullWidth" parent="Widget.Material3.Button.TextButton.Dialog.Flush">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:maxWidth">@null</item>
        <item name="android:textColor">@color/neon_cyan</item>
    </style>

    <style name="ThemeOverlay.MaterialAlertDialog.Centered.FullWidthButtons" parent="ThemeOverlay.Material3.MaterialAlertDialog.Centered">
        <item name="materialAlertDialogButtonSpacerVisibility">2</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
    </style>

    <style name="ThemeOverlay.MaterialAlertDialog.FullWidthButtons" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogButtonSpacerVisibility">2</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Button.TextButton.Dialog.FullWidth</item>
        <item name="android:windowBackground">@color/dark_bg_secondary</item>
        <item name="shapeAppearanceOverlay">@style/DialogShapeAppearance</item>
    </style>

    <style name="DialogShapeAppearance" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">@dimen/card_radius_large</item>
    </style>

    <style name="CardInfoStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_radius_medium</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="cardBackgroundColor">@color/dark_card</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textAppearance">?textAppearanceTitleLarge</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingBottom">@dimen/spacing_small</item>
    </style>

    <style name="SectionDescription">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:textColor">@color/text_secondary_neon</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="ToolbarTitleStyle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="ModernToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/ToolbarTitleStyle</item>
        <item name="android:minHeight">?attr/actionBarSize</item>
        <item name="contentInsetStart">0dp</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
        <item name="android:background">@color/dark_bg_primary</item>
    </style>

    <style name="NoActionBarTheme" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Dark Neon Base Theme -->
    <style name="Theme.DarkNeon" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_blue</item>
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="colorSecondaryVariant">@color/neon_purple</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorBackground">@color/dark_bg_primary</item>
        <item name="colorOnPrimary">@color/dark_bg_primary</item>
        <item name="colorOnSecondary">@color/dark_bg_primary</item>
        <item name="colorOnSurface">@color/text_primary_neon</item>
        <item name="colorOnBackground">@color/text_primary_neon</item>
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>