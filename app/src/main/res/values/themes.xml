<resources>

    <style name="Base.AppTheme.Light" parent="Theme.Material3.DynamicColors.Light.Rikka">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_blue</item>
        <item name="colorOnPrimary">@color/dark_bg_primary</item>
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="colorOnSecondary">@color/dark_bg_primary</item>
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_bg_primary</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:textAppearanceListItem">?textAppearanceSubtitle1</item>
        <item name="android:colorAccent">@color/neon_magenta</item>
        <item name="android:colorControlActivated">@color/neon_cyan</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
        <item name="toolbarStyle">@style/ModernToolbarStyle</item>
    </style>

    <style name="Theme.Light" parent="Base.AppTheme.Light" />

    <style name="Base.AppTheme" parent="Theme.Material3.DynamicColors.Dark.Rikka">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:textAppearanceListItem">?textAppearanceSubtitle1</item>
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_blue</item>
        <item name="colorOnPrimary">@color/dark_bg_primary</item>
        <item name="colorSecondary">@color/neon_magenta</item>
        <item name="colorOnSecondary">@color/dark_bg_primary</item>
        <item name="android:colorAccent">@color/neon_magenta</item>
        <item name="android:colorControlActivated">@color/neon_cyan</item>
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_bg_primary</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
        <item name="toolbarStyle">@style/ModernToolbarStyle</item>
    </style>

    <style name="MyActionBar" parent="@style/Widget.Material3.ActionBar.Solid">
        <item name="background">@color/dark_surface</item>
        <item name="contentInsetStart">5dp</item>
    </style>

    <style name="Theme" parent="Base.AppTheme" />

    <style name="DeviceInfoDialogLabel">
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body1</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="DeviceInfoDialogValue">
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="android:textColor">@color/text_neon_secondary</item>
        <item name="android:paddingBottom">@dimen/spacing_large</item>
    </style>

    <style name="StatusCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius_large</item>
        <item name="cardElevation">@dimen/card_elevation_high</item>
        <item name="android:layout_marginBottom">@dimen/spacing_medium</item>
        <item name="contentPadding">@dimen/spacing_medium</item>
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="StatusCardTitle">
        <item name="android:textAppearance">?textAppearanceTitleMedium</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="StatusCardSummary">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:textColor">@color/text_neon_secondary</item>
        <item name="android:alpha">0.9</item>
    </style>

    <style name="ModernButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">@dimen/button_min_width</item>
        <item name="cornerRadius">@dimen/card_radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/dark_bg_primary</item>
        <item name="backgroundTint">@color/neon_cyan</item>
    </style>

    <style name="ModernButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">@dimen/button_min_width</item>
        <item name="cornerRadius">@dimen/card_radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="strokeColor">@color/neon_cyan</item>
    </style>

    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/NavActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="android:minHeight">@dimen/nav_bar_height</item>
        <item name="elevation">@dimen/card_elevation_high</item>
        <item name="android:background">@color/dark_bg_secondary</item>
    </style>

    <style name="NavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/neon_cyan</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>

</resources>